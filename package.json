{
  "name": "wyrdfold",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "nx run-many --target=test --all",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "test:e2e": "nx run-many --target=e2e --all",
    "test:lighthouse": "lhci autorun",
    "test:lighthouse:collect": "lhci collect",
    "test:lighthouse:assert": "lhci assert",
    "test:python": "nx run-many --target=lint,typecheck,test --projects=wyrdfold-api",
    "typecheck": "nx run-many --target=typecheck --all",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "size:noop": "true",
    "pom": "pnpm typecheck && pnpm lint:fix && pnpm format && pnpm test && pnpm test:python && pnpm test:coverage && pnpm test:e2e && pnpm test:lighthouse",
    "pom:affected": "nx affected -t typecheck && nx affected -t lint --fix && pnpm format && nx affected -t test --coverage && nx affected -t e2e",
    "affected": "nx affected -t lint test build typecheck e2e",
    "dev": "nx run-many --target=dev --all",
    "postinstall": "command -v uv >/dev/null && uv sync || echo 'uv not found — skipping Python deps (install: https://docs.astral.sh/uv/)'",
    "prepare": "husky",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:gen-types": "supabase gen types typescript --linked > apps/wyrdfold/src/lib/supabase/types.ts"
  },
  "private": true,
  "browserslist": [
    "last 2 versions",
    ">= 5% in US",
    "not dead",
    "not op_mini all",
    "not kaios > 0"
  ],
  "dependencies": {
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.3",
    "@react-email/components": "1.0.12",
    "@sentry/nextjs": "10.48.0",
    "@supabase/supabase-js": "2.103.0",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "botid": "^1.5.11",
    "caniuse-lite": "1.0.30001788",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "isomorphic-dompurify": "2.26.0",
    "jose": "^6.2.2",
    "lucide-react": "0.577.0",
    "minisearch": "^7.2.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.1",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "resend": "6.11.0",
    "schema-dts": "^1.1.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "16.2.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/devkit": "22.6.5",
    "@nx/docker": "22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/next": "22.6.5",
    "@nx/playwright": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/s3-cache": "^5.0.4",
    "@nx/storybook": "22.6.5",
    "@nx/vite": "22.6.5",
    "@playwright/test": "1.59.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/nextjs-vite": "10.3.5",
