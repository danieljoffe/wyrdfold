{
  "name": "wyrdfold",
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "nx run-many --target=test --all",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "test:e2e": "nx run-many --target=e2e --all",
    "test:python": "nx run-many --target=lint,typecheck,test --projects=wyrdfold-api",
    "typecheck": "nx run-many --target=typecheck --all",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "analyze": "nx run wyrdfold:analyze",
    "lhci": "lhci autorun",
    "pom": "pnpm typecheck && pnpm lint:fix && pnpm format && pnpm test && pnpm test:python && pnpm test:coverage && pnpm test:e2e",
    "pom:affected": "nx affected -t typecheck && nx affected -t lint --fix && pnpm format && nx affected -t test --coverage && nx affected -t e2e",
    "affected": "nx affected -t lint test build typecheck e2e",
    "dev": "nx run-many --target=dev --all",
    "postinstall": "command -v uv >/dev/null && uv sync || echo 'uv not found — skipping Python deps (install: https://docs.astral.sh/uv/)'",
    "prepare": "husky",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:gen-types": "supabase gen types typescript --linked > apps/wyrdfold/src/lib/supabase/types.ts"
  },
  "private": true,
  "browserslist": [
    "last 2 versions",
    ">= 5% in US",
    "not dead",
    "not op_mini all",
    "not kaios > 0"
  ],
  "dependencies": {
    "@sentry/nextjs": "10.58.0",
    "@supabase/supabase-js": "2.108.2",
    "caniuse-lite": "1.0.30001799",
    "clsx": "^2.1.1",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.14.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/devkit": "22.7.5",
    "@nx/docker": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/next": "22.7.5",
    "@nx/playwright": "22.7.5",
    "@playwright/test": "1.61.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.41",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "~0.2.38",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-jest": "^30.0.2",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "^9.1.7",
    "jest": "30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "30.4.1",
    "jest-util": "^30.0.2",
    "jsdom": "^29.0.2",
    "knip": "^6.17.1",
    "lint-staged": "17.0.7",
    "nx": "23.0.0",
    "playwright": "1.61.0",
    "postcss": "8.5.15",
    "prettier": "^3.8.2",
    "sharp": "^0.35.1",
    "supabase": "2.107.0",
    "tailwindcss": "4.3.1",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.61.1"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0",
      "tmp": "^0.2.4",
      "form-data": "^4.0.6",
      "js-yaml": "^4.2.0",
      "@opentelemetry/core": "2.8.0",
      "@opentelemetry/resources": "2.8.0",
      "@opentelemetry/sdk-trace-base": "2.8.0",
      "@typescript-eslint/utils": "8.58.2",
      "@typescript-eslint/type-utils": "8.58.2",
      "@typescript-eslint/eslint-plugin": "8.58.2",
      "@typescript-eslint/parser": "8.58.2",
      "@typescript-eslint/types": "8.58.2",
      "@typescript-eslint/typescript-estree": "8.58.2",
      "@typescript-eslint/visitor-keys": "8.58.2",
      "@typescript-eslint/scope-manager": "8.58.2",
      "next>postcss": "8.5.15",
      "uuid": "^11.1.1",
      "vite": "7.3.5",
      "@vitest/browser": ">=4.1.6",
      "esbuild": "^0.28.1",
      "undici": "^7.28.0",
      "dompurify": "^3.4.11"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "nx",
      "oxc-resolver",
      "supabase",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
