# Supabase — service role only (server-side)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# HS256 JWT secret from the Supabase project (Project Settings → API → JWT
# Settings). Used to verify Bearer tokens minted by Supabase Auth.
SUPABASE_JWT_SECRET=

# Shared secret between Next.js proxy routes and this API (x-api-key header).
# Reserved for cron / poller / batch jobs — user requests use Supabase JWTs.
# Generate: `openssl rand -hex 32`
WYRDFOLD_API_KEY=

# Greenhouse polling knobs
GREENHOUSE_DELAY_MS=200
SCORE_NORMALIZER=30

# Host header allowlist — comma-separated. Include Railway public domain and
# any private networking hostnames the Next.js proxy will call.
# Example: wyrdfold-api.up.railway.app,wyrdfold-api.railway.internal
ALLOWED_HOSTS=*

# Sentry — leave DSN empty to disable (local dev, tests).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
