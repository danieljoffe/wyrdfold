# ============================================================================
# WyrdFold API — environment template
#
# REQUIRED: only the [Required] section must be filled in for the API to
# start and serve requests. Everything else is optional and degrades
# gracefully (the relevant feature is skipped or mocked when unset).
# ============================================================================

# ----------------------------------------------------------------------------
# [Required] Supabase — service role only (server-side)
# Create a project at https://supabase.com, then: Settings → API.
# ----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Anon (publishable) key — only needed once per-user data access moves
# onto the RLS-enforced per-request user client (#79). Unset is fine
# until then; today's code paths use the service-role key above.
SUPABASE_ANON_KEY=

# ----------------------------------------------------------------------------
# [Required] Shared secret between Next.js proxy routes and this API
# (x-api-key header). Reserved for cron / poller / batch jobs — user
# requests use Supabase JWTs. Generate: `openssl rand -hex 32`
# Must match WYRDFOLD_API_KEY in the Next.js app's env.
#
# SECURITY (#29 round 3 / H4): today this key is also accepted as full auth
# on the user-data routers (jobs/targets/sources/analysis/tailor/experience)
# via verify_api_key_or_jwt, so a leak authenticates against user data. The
# migration path is WYRDFOLD_CRON_KEY below — point automation at it, then
# retire this broad key.
# ----------------------------------------------------------------------------
WYRDFOLD_API_KEY=

# ----------------------------------------------------------------------------
# [Optional] Dedicated cron/automation key (#29 round 3 / H4). When set, it
# is accepted ONLY on the strictly-operator routes (verify_api_key: /poll,
# /discovery, /admin, jobs rescore + backfill-salary, sources POST/seed,
# targets funnel) — NOT on the user-data routers. Point cron / poller /
# batch jobs at this key so a leak of the automation credential cannot reach
# user data. Generate: `openssl rand -hex 32`. Empty = disabled (the broad
# WYRDFOLD_API_KEY keeps working everywhere it does today).
# ----------------------------------------------------------------------------
WYRDFOLD_CRON_KEY=

# ----------------------------------------------------------------------------
# [Required] Host header allowlist — comma-separated. `*` is fine for
# local dev. In production include your public domain and any private
# networking hostnames the Next.js proxy will call.
# Example: wyrdfold-api.up.railway.app,wyrdfold-api.railway.internal
# ----------------------------------------------------------------------------
ALLOWED_HOSTS=*

# ----------------------------------------------------------------------------
# LLM provider — "mock" (default) boots without any key and returns canned
# responses; fine for poking at the app, useless for real grading. Set ONE
# of the following for real LLM calls:
#   LLM_PROVIDER=anthropic  + ANTHROPIC_API_KEY   (direct Anthropic SDK)
#   LLM_PROVIDER=openrouter + OPENROUTER_API_KEY  (same calls via OpenRouter)
# ----------------------------------------------------------------------------
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ----------------------------------------------------------------------------
# [Optional] Embeddings — "mock" (default) needs no key. Set to "voyage"
# + key for real embeddings (resume chunk similarity).
# ----------------------------------------------------------------------------
EMBEDDINGS_PROVIDER=mock
VOYAGE_API_KEY=

# ----------------------------------------------------------------------------
# [Optional] Integrations — each is skipped cleanly when unset.
# ----------------------------------------------------------------------------
# Brave Search — powers target-driven job-source discovery. Empty key
# disables discovery entirely. Free tier: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=
# Firecrawl — JS-rendered page extraction fallback for manual job adds.
FIRECRAWL_API_KEY=
# Twilio SMS notifications — set all three to enable; otherwise SMS is skipped.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Sentry — leave DSN empty to disable (local dev, tests).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Job-alert email notifications: the API posts alerts to the Next.js app,
# which sends via Resend. Both empty = alerts skipped.
NEXT_APP_URL=
JOB_ALERT_SECRET=

# ----------------------------------------------------------------------------
# [Recommended] Background polling — the in-process scheduler is the PRIMARY
# poll trigger. Set POLL_SCHEDULER_ENABLED=true (e.g. in Railway) and the
# backend drives ingestion itself every POLL_TICK_MINUTES; no external cron
# needed. The Vercel cron has been removed (it broke once and ingestion
# silently died for 10+ days). Each scheduled poll takes a Postgres advisory
# lock, so even with multiple replicas — or if you re-add an external cron —
# only ONE poll runs at a time and upserts are idempotent regardless.
# External cron can still call POST /poll/due to reach the same code path.
# ----------------------------------------------------------------------------
POLL_SCHEDULER_ENABLED=false
POLL_TICK_MINUTES=30

# Auto-recovery + health alerting (poll-outage hardening). The scheduler
# re-enables a source the failure-backoff auto-disabled once it's been
# disabled longer than SOURCE_RECOVERY_AFTER_HOURS (so a transient ATS-wide
# outage can't kill ingestion forever), and alerts (via Sentry) when no new
# jobs have been ingested in INGESTION_MAX_JOB_AGE_HOURS or a majority of
# sources are disabled. Set any threshold to 0 to disable that piece.
SOURCE_RECOVERY_AFTER_HOURS=24
INGESTION_HEALTH_CHECK_ENABLED=true
INGESTION_MAX_JOB_AGE_HOURS=48
INGESTION_MASS_DISABLE_RATIO=0.5

# ----------------------------------------------------------------------------
# [Optional] LLM pipeline feature flags. All ship FALSE; the poller falls
# back to keyword scoring. For the full LLM matching pipeline set both
# phase flags true (requires a real LLM_PROVIDER).
# ----------------------------------------------------------------------------
PHASE1_TRIAGE_ENABLED=false
PHASE2_ENABLED=false
RECENCY_DECAY_ENABLED=false
LOGISTICS_EXTRACTION_ENABLED=false
PHASE2_SENIORITY_GATE_ENABLED=false
URL_HEALTH_CHECK_ENABLED=false

# ----------------------------------------------------------------------------
# [Optional] Retention purge for append-only operational logs (#29 P3).
# OFF by default — self-host keeps every row until you choose a window.
# When enabled, the scheduler ticks every RETENTION_PURGE_TICK_HOURS and
# deletes rows older than the per-table window below; 0 = keep forever.
# External cron can POST /admin/retention/purge instead of enabling this.
# ----------------------------------------------------------------------------
RETENTION_PURGE_ENABLED=false
RETENTION_PURGE_TICK_HOURS=24
LLM_COSTS_RETENTION_DAYS=365
NOTIFICATIONS_SENT_RETENTION_DAYS=180

# ----------------------------------------------------------------------------
# [Optional] Cost guardrails (USD). Rolling windows over llm_costs.
# Set a window to 0 to disable it. API-key callers (cron) bypass the HTTP
# gate; background work is charged to the target's activator.
# ----------------------------------------------------------------------------
USER_LLM_HOURLY_BUDGET_USD=1.0
USER_LLM_DAILY_BUDGET_USD=5.0
USER_LLM_MONTHLY_BUDGET_USD=5.0
GLOBAL_LLM_DAILY_BUDGET_USD=10.0
ANALYSIS_DAILY_LIMIT=20
PHASE2_DAILY_CAP=20

# ----------------------------------------------------------------------------
# [Optional] Misc knobs (defaults are sensible — see app/config.py for the
# full list and per-setting docs).
# ----------------------------------------------------------------------------
# CORS allowlist for browser calls. Empty = server-to-server only, which is
# correct for the default setup (the Next.js BFF proxies server-side).
CORS_ALLOWED_ORIGINS=
GREENHOUSE_DELAY_MS=200
SCORE_NORMALIZER=30
RATE_LIMIT_ENABLED=true

# Logging format. `text` (default) keeps stdlib/uvicorn output for local
# dev; `json` emits one JSON object per record so a log-aggregation tool
# (Better Stack, Datadog, etc.) can index by field. Covers app loggers;
# uvicorn's own loggers keep their stock format — see
# app/logging_config.py + the README Operations section.
LOG_FORMAT=text

# ----------------------------------------------------------------------------
# [Optional] BYOK (#5) — only needed for a multi-user hosted instance where
# each user supplies their own provider keys. Single-tenant self-host leaves
# this unset and uses the operator keys above. Master key for AES-256-GCM
# encryption of stored per-user keys: base64 of 32 random bytes.
#   openssl rand -base64 32
# Rotating it orphans all previously-stored user keys (they can't decrypt).
# ----------------------------------------------------------------------------
BYOK_MASTER_KEY=
