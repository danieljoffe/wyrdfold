# ============================================================================
# WyrdFold web app (Next.js) — environment template
# [Required] unless noted otherwise.
# ============================================================================

# Supabase (auth) — Settings → API in your Supabase project. The browser-side
# code uses the anon/publishable key only.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_ID=your-anon-key

# WyrdFold API (Python/FastAPI backend — proxied via /api/* BFF routes).
# `pnpm nx dev wyrdfold-api` serves it on port 8001. Also the backend the
# public waitlist BFF (/api/waitlist) forwards to: the API holds the Supabase
# service-role key and writes the RLS deny-all `waitlist_signups` table, so the
# web app NO LONGER needs SUPABASE_SERVICE_ROLE_KEY (audit #29 — keeps the
# service-role key out of the web/Vercel env entirely).
WYRDFOLD_API_URL=http://localhost:8001

# [#29] Narrow operator-only key the /api/jobs/poll cron forwards to the API's
# /poll as x-api-key (must match WYRDFOLD_CRON_KEY in the API's env). REQUIRED —
# the cron route uses ONLY this key, no fallback. Generate: `openssl rand -hex 32`
WYRDFOLD_CRON_KEY=

# Legacy shared secret — no longer read by the frontend (the poll cron now uses
# WYRDFOLD_CRON_KEY above). Safe to remove from this app's env.
WYRDFOLD_API_KEY=

# [Optional] Secret protecting the /api/jobs/poll cron route (Vercel cron
# sends it as a Bearer token). Only needed when using Vercel cron.
CRON_SECRET=

# [Optional] Sentry — leave empty to disable error reporting.
NEXT_PUBLIC_SENTRY_CONFIG_ID=
# Build-time only: uploads source maps during `next build`.
SENTRY_AUTH_TOKEN=
